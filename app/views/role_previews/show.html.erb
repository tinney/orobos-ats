<% content_for(:title) { "#{@role.title} — Preview — #{@company&.name}" } %>

<div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden">
  <div class="px-6 py-6 border-b border-gray-200">
    <h1 class="text-2xl font-bold text-gray-900"><%= @role.title %></h1>
    <div class="mt-2 flex items-center space-x-3 text-sm text-gray-500">
      <% if @role.location.present? %>
        <span><%= @role.location %></span>
      <% end %>
      <% if @role.remote? %>
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Remote</span>
      <% end %>
    </div>
    <% if @role.salary_range.present? %>
      <div class="mt-2 text-sm text-gray-600"><%= @role.salary_range %></div>
    <% end %>
  </div>

  <% if @role.description.present? %>
    <div class="px-6 py-5">
      <h2 class="text-lg font-medium text-gray-900 mb-3">About this role</h2>
      <div class="prose prose-sm max-w-none">
        <%= @role.description %>
      </div>
    </div>
  <% end %>
</div>
