<div class="px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">My Interviews</h1>

  <% if @interviews_by_role.any? %>
    <div class="space-y-8">
      <% @interviews_by_role.each do |role, interviews| %>
        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
          <%# Role group header %>
          <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold text-gray-900"><%= role.title %></h2>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-indigo-100 text-indigo-800">
                <%= pluralize(interviews.size, "interview") %>
              </span>
            </div>
          </div>

          <%# Table of assignments for this role %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Candidate</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Interview Phase</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Scheduled Time</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Your Role</th>
                  <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% interviews.each do |interview| %>
                  <tr class="hover:bg-gray-50">
                    <%# Candidate name %>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <%= link_to interview.application.candidate.full_name,
                          admin_application_path(interview.application),
                          class: "text-sm font-medium text-indigo-600 hover:text-indigo-900" %>
                    </td>

                    <%# Interview phase %>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex items-center gap-2">
                        <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-gray-200 text-gray-600 text-xs font-medium">
                          <%= interview.interview_phase.position + 1 %>
                        </span>
                        <span class="text-sm text-gray-900"><%= interview.interview_phase.name %></span>
                      </div>
                    </td>

                    <%# Scheduled time %>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <% if interview.scheduled_at.present? %>
                        <div class="text-sm text-gray-900"><%= interview.scheduled_at.strftime("%b %d, %Y") %></div>
                        <div class="text-xs text-gray-500"><%= interview.scheduled_at.strftime("%I:%M %p") %></div>
                      <% else %>
                        <span class="text-sm text-gray-400 italic">Not scheduled</span>
                      <% end %>
                    </td>

                    <%# Status badge %>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                        <%= case interview.status
                            when 'unscheduled' then 'bg-gray-100 text-gray-800'
                            when 'scheduled' then 'bg-blue-100 text-blue-800'
                            when 'complete' then 'bg-green-100 text-green-800'
                            when 'cancelled' then 'bg-red-100 text-red-800'
                            end %>">
                        <%= interview.status.titleize %>
                      </span>
                    </td>

                    <%# Assignment role (interviewer vs coordinator) %>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <% assignment = @assignment_roles[interview.id] %>
                      <% if assignment.include?("Interviewer") && assignment.include?("Coordinator") %>
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-purple-100 text-purple-800">Interviewer</span>
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-amber-100 text-amber-800 ml-1">Coordinator</span>
                      <% elsif assignment.include?("Interviewer") %>
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-purple-100 text-purple-800">Interviewer</span>
                      <% elsif assignment.include?("Coordinator") %>
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-amber-100 text-amber-800">Coordinator</span>
                      <% end %>
                    </td>

                    <%# Actions %>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                      <div class="flex items-center justify-end gap-3">
                        <% if interview.scorecards.any? { |sc| sc.user_id == current_user.id } %>
                          <% sc = interview.scorecards.find { |s| s.user_id == current_user.id } %>
                          <%= link_to "Edit Scorecard", edit_admin_interview_scorecard_path(interview, sc),
                              class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                        <% elsif interview.active? %>
                          <%= link_to "Submit Scorecard", new_admin_interview_scorecard_path(interview),
                              class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                        <% end %>
                        <%= link_to "View", admin_application_path(interview.application),
                            class: "text-gray-500 hover:text-gray-700" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border border-gray-200 px-6 py-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
      </svg>
      <h3 class="mt-2 text-sm font-semibold text-gray-900">No interviews assigned</h3>
      <p class="mt-1 text-sm text-gray-500">You don't have any interview assignments yet.</p>
    </div>
  <% end %>
</div>
