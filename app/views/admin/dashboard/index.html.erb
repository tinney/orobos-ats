<div class="px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>

  <%# Stage summary cards %>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
    <% ApplicationSubmission::STATUSES.each do |status| %>
      <div class="bg-white rounded-lg border border-gray-200 px-4 py-5 text-center">
        <p class="text-sm font-medium text-gray-500"><%= status.titleize %></p>
        <p class="text-2xl font-bold text-gray-900 mt-1"><%= @stage_counts[status] || 0 %></p>
      </div>
    <% end %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Pipeline by Role</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
            <% ApplicationSubmission::STATUSES.each do |status| %>
              <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider"><%= status.titleize %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @roles.each do |role| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to role.title, admin_role_applications_path(role), class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
              </td>
              <% ApplicationSubmission::STATUSES.each do |status| %>
                <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                  <%= @role_counts[[role.title, status]] || 0 %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
