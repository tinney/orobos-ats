<% content_for(:title, "Edit #{@user.full_name} — Admin") %>

<div class="w-full max-w-lg mx-auto">
  <div class="mb-6">
    <%= link_to "← Back to Team", admin_users_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
  <h1 class="text-2xl font-bold text-gray-900 mb-1">Edit Team Member</h1>
  <p class="text-sm text-gray-500 mb-6">
    Current role: <%= render "role_badge", user: @user %>
    <span class="text-gray-400 ml-1">— use Promote/Demote on the team page to change roles</span>
  </p>
  <%= render "form", user: @user %>
</div>
