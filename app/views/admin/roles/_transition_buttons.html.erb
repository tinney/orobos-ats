<%# Renders available state transition buttons for a role as a dropdown menu %>
<%
  transition_config = {
    "published"     => { label: "Publish",        css: "text-green-700 hover:bg-green-50", icon_color: "text-green-500", destructive: false },
    "internal_only" => { label: "Make Internal",   css: "text-yellow-700 hover:bg-yellow-50", icon_color: "text-yellow-500", destructive: false },
    "closed"        => { label: "Close Role",      css: "text-red-700 hover:bg-red-50", icon_color: "text-red-500", destructive: true },
    "draft"         => { label: "Revert to Draft", css: "text-gray-700 hover:bg-gray-50", icon_color: "text-gray-500", destructive: false }
  }

  available_transitions = Role::TRANSITIONS.fetch(role.status, [])
  # Filter out "published" if the role isn't publishable (requires phase owner)
  available_transitions = available_transitions.reject { |t| t == "published" && !role.publishable? }
%>

<% if available_transitions.any? %>
  <div data-controller="role-transition" class="relative inline-block text-left">
    <%# Dropdown trigger button %>
    <button type="button"
            data-action="click->role-transition#toggle"
            class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 shadow-sm"
            aria-haspopup="true">
      Status Actions
      <svg class="ml-2 -mr-0.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </button>

    <%# Dropdown menu %>
    <div data-role-transition-target="menu"
         class="hidden origin-top-right absolute right-0 mt-2 w-56 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 z-50">
      <div class="py-1" role="menu" aria-orientation="vertical">
        <% available_transitions.each do |target_status| %>
          <% config = transition_config[target_status] %>
          <% if config %>
            <% confirm_message = if config[:destructive]
                 "Are you sure you want to close \"#{role.title}\"? This will remove it from public listings. You can reopen it later by reverting to draft."
               else
                 "Are you sure you want to #{config[:label].downcase} \"#{role.title}\"?"
               end %>
            <%= form_with url: transition_admin_role_path(role, status: target_status),
                          method: :patch,
                          class: "block",
                          data: {
                            action: config[:destructive] ?
                              "submit->role-transition#confirmDestructive" :
                              "submit->role-transition#confirmTransition",
                            role_transition_confirm_param: confirm_message
                          } do %>
              <button type="submit"
                      class="w-full text-left px-4 py-2 text-sm <%= config[:css] %> flex items-center"
                      role="menuitem">
                <% if target_status == "published" %>
                  <svg class="mr-3 h-4 w-4 <%= config[:icon_color] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                <% elsif target_status == "internal_only" %>
                  <svg class="mr-3 h-4 w-4 <%= config[:icon_color] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                  </svg>
                <% elsif target_status == "closed" %>
                  <svg class="mr-3 h-4 w-4 <%= config[:icon_color] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
                  </svg>
                <% elsif target_status == "draft" %>
                  <svg class="mr-3 h-4 w-4 <%= config[:icon_color] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                <% end %>
                <%= config[:label] %>
              </button>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
