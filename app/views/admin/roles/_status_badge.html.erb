<%
  status_classes = {
    "draft"         => "bg-gray-100 text-gray-800",
    "published"     => "bg-green-100 text-green-800",
    "internal_only" => "bg-yellow-100 text-yellow-800",
    "closed"        => "bg-red-100 text-red-800"
  }
%>
<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_classes[role.status] %>">
  <%= role.status.titleize %>
</span>
