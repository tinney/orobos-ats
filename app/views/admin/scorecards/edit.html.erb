<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="max-w-2xl mx-auto">
    <div class="mb-6">
      <%= link_to "← Back", admin_application_path(@interview.application), class: "text-sm text-indigo-600 hover:text-indigo-800" %>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 mb-2">Edit Scorecard</h1>
    <p class="text-sm text-gray-500 mb-6">
      <%= @interview.application.candidate.full_name %> — <%= @interview.interview_phase.name %>
    </p>

    <div class="bg-white rounded-lg border border-gray-200 px-6 py-6">
      <%= render "form", scorecard: @scorecard, interview: @interview %>
    </div>
  </div>
</div>
