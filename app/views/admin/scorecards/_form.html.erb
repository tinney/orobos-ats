<%= form_with model: scorecard, url: scorecard.persisted? ? admin_interview_scorecard_path(interview, scorecard) : admin_interview_scorecards_path(interview),
    method: scorecard.persisted? ? :patch : :post, local: true, class: "space-y-6" do |f| %>

  <% if scorecard.errors.any? %>
    <div class="rounded-md bg-red-50 p-4 mb-4">
      <ul class="list-disc list-inside text-sm text-red-800">
        <% scorecard.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% has_template = interview.interview_phase.scorecard_template.present? %>
  <div>
    <h3 class="text-sm font-medium text-gray-900 mb-3">Rating Categories (1-5)</h3>
    <% if has_template && !scorecard.persisted? %>
      <p class="text-xs text-indigo-600 mb-3">Categories pre-filled from the "<%= interview.interview_phase.scorecard_template.name %>" template.</p>
    <% end %>
    <div id="categories-container" class="space-y-4">
      <%= f.fields_for :scorecard_categories do |cf| %>
        <div class="flex items-center gap-4">
          <% if has_template && !scorecard.persisted? && cf.object.name.present? %>
            <%# Template-sourced category — name is pre-filled and read-only %>
            <%= cf.hidden_field :name %>
            <span class="flex-1 text-sm font-medium text-gray-900 py-2 px-3 bg-gray-50 rounded-md border border-gray-200"><%= cf.object.name %></span>
          <% else %>
            <%= cf.text_field :name, placeholder: "Category name (e.g., Technical Skills)",
                class: "flex-1 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          <% end %>
          <%= cf.select :rating, (1..5).map { |n| [n, n] }, { include_blank: "Rating" },
              class: "rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          <% unless has_template && !scorecard.persisted? %>
            <label class="flex items-center">
              <%= cf.check_box :_destroy, class: "rounded border-gray-300 text-red-600 focus:ring-red-500" %>
              <span class="ml-1 text-xs text-red-600">Remove</span>
            </label>
          <% end %>
        </div>
      <% end %>
    </div>
    <% unless has_template && !scorecard.persisted? %>
      <p class="text-xs text-gray-500 mt-2">Add categories to rate different aspects of the interview.</p>
    <% end %>
  </div>

  <div>
    <%= f.label :notes, "Notes", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :notes, rows: 6,
        class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
        placeholder: "Your observations and feedback..." %>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit "Save Scorecard",
        class: "inline-flex items-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
