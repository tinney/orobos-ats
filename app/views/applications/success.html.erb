<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 text-center">
  <div class="bg-white rounded-lg border border-gray-200 px-6 sm:px-8 py-10 sm:py-12">
    <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-green-100 mb-6">
      <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
    </div>

    <h1 class="text-xl sm:text-2xl font-bold text-gray-900 mb-4">Application Submitted!</h1>
    <p class="text-gray-600 mb-2">Thank you for applying for <strong><%= @role.title %></strong> at <strong><%= current_company.name %></strong>.</p>
    <p class="text-gray-500 text-sm mb-8">We've sent a confirmation email to your inbox. We'll review your application and get back to you soon.</p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to "View More Positions", careers_path,
          class: "inline-flex items-center justify-center rounded-md px-6 py-2 text-sm font-medium border border-gray-300 text-gray-700 bg-white hover:bg-gray-50" %>
    </div>
  </div>
</div>
