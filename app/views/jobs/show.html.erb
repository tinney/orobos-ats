<div class="max-w-3xl mx-auto">
  <div class="mb-6">
    <%= link_to "← Back to all positions", careers_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4"><%= @role.title %></h1>

  <div class="flex flex-wrap gap-4 text-sm text-gray-500 mb-8">
    <% if @role.location.present? %>
      <span><%= @role.location %></span>
    <% end %>
    <% if @role.remote? %>
      <span class="inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-medium text-green-700">Remote</span>
    <% end %>
    <% if @role.salary_range.present? %>
      <span><%= @role.salary_range %></span>
    <% end %>
  </div>

  <div class="prose max-w-none">
    <%= @role.description %>
  </div>

  <div class="mt-8">
    <%= link_to "Apply Now", job_application_path(slug: @role.slug),
        class: "inline-flex items-center justify-center rounded-md border border-transparent px-6 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2",
        style: "background-color: #{current_company.primary_color || '#4F46E5'};" %>
  </div>
</div>
