<h2 class="text-xl font-semibold text-gray-900 mb-2">Create your account</h2>
<p class="text-sm text-gray-500 mb-6">Get started with Ouroboros in under a minute. No credit card required.</p>

<%= form_with url: signup_path, scope: :signup, method: :post, local: true, class: "space-y-6",
    data: { controller: "signup-form", action: "submit->signup-form#validate" },
    html: { novalidate: true } do |f| %>

  <%# Company Details Section %>
  <fieldset class="space-y-4">
    <legend class="text-sm font-semibold text-gray-900 uppercase tracking-wide">Company Details</legend>

    <div>
      <%= f.label :company_name, "Company Name", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :company_name,
          value: @form_data&.dig(:company_name),
          required: true,
          autocomplete: "organization",
          data: { signup_form_target: "companyName", action: "input->signup-form#clearFieldError" },
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
          placeholder: "Acme Corp" %>
    </div>

    <div data-controller="subdomain-validation" data-subdomain-validation-url-value="<%= check_subdomain_path %>">
      <%= f.label :subdomain, "Subdomain", class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1 flex rounded-md shadow-sm">
        <%= f.text_field :subdomain,
            value: @form_data&.dig(:subdomain),
            required: true,
            autocomplete: "off",
            spellcheck: "false",
            data: {
              subdomain_validation_target: "input",
              signup_form_target: "subdomain",
              action: "input->subdomain-validation#validate input->signup-form#clearFieldError"
            },
            class: "block w-full min-w-0 flex-1 rounded-l-md border-gray-300 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
            placeholder: "acme" %>
        <span class="inline-flex items-center rounded-r-md border border-l-0 border-gray-300 bg-gray-50 px-3 text-sm text-gray-500">
          .ouroboros.app
        </span>
      </div>
      <div data-subdomain-validation-target="feedback" class="mt-1.5 text-sm flex items-center gap-1"></div>
      <p class="mt-1 text-xs text-gray-400">Lowercase letters, numbers, and hyphens only. Min 3 characters.</p>
    </div>
  </fieldset>

  <hr class="border-gray-200">

  <%# Admin Account Section %>
  <fieldset class="space-y-4">
    <legend class="text-sm font-semibold text-gray-900 uppercase tracking-wide">Admin Account</legend>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :admin_first_name, "First Name", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :admin_first_name,
            value: @form_data&.dig(:admin_first_name),
            required: true,
            autocomplete: "given-name",
            data: { signup_form_target: "adminFirstName", action: "input->signup-form#clearFieldError" },
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
            placeholder: "Jane" %>
      </div>

      <div>
        <%= f.label :admin_last_name, "Last Name", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :admin_last_name,
            value: @form_data&.dig(:admin_last_name),
            required: true,
            autocomplete: "family-name",
            data: { signup_form_target: "adminLastName", action: "input->signup-form#clearFieldError" },
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
            placeholder: "Smith" %>
      </div>
    </div>

    <div>
      <%= f.label :admin_email, "Email Address", class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :admin_email,
          value: @form_data&.dig(:admin_email),
          required: true,
          autocomplete: "email",
          data: { signup_form_target: "adminEmail", action: "input->signup-form#clearFieldError" },
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
          placeholder: "jane@acme.com" %>
      <p class="mt-1 text-xs text-gray-400">We'll send you a magic link to sign in.</p>
    </div>
  </fieldset>

  <div class="pt-2">
    <%= f.submit "Create Account",
        data: { signup_form_target: "submitButton" },
        class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-150 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" %>
  </div>

  <p class="text-center text-xs text-gray-400">
    By creating an account, you agree to our terms of service.
  </p>
<% end %>
