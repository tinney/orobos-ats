<div class="text-center">
  <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-green-100">
    <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
    </svg>
  </div>

  <h2 class="mt-4 text-xl font-semibold text-gray-900">Account Created!</h2>

  <p class="mt-2 text-sm text-gray-600">
    Your workspace is ready at
    <strong class="text-indigo-600"><%= @subdomain %>.ouroboros.app</strong>
  </p>

  <div class="mt-6 rounded-md bg-indigo-50 p-4">
    <div class="flex items-start">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
      </div>
      <p class="ml-3 text-sm text-indigo-700">
        Check your email for a magic link to sign in. The link expires in 15 minutes.
      </p>
    </div>
  </div>
</div>
