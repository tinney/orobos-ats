<% content_for(:title, "Ouroboros — Modern Job Application Tracking") %>

<%# ===== NAVIGATION ===== %>
<nav class="bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex items-center space-x-2">
        <svg class="h-8 w-8 text-indigo-600" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="2.5"/>
          <path d="M16 6 C22 6 26 10 26 16 C26 22 22 26 16 26 C10 26 6 22 6 16 C6 12 9 9 12 9 C15 9 17 11 17 14 C17 17 15 19 12 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        </svg>
        <span class="text-xl font-bold text-gray-900">Ouroboros</span>
      </div>
      <div class="flex items-center space-x-4">
        <a href="<%= signup_path %>" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-md shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition">
          Get Started
        </a>
      </div>
    </div>
  </div>
</nav>

<%# ===== HERO SECTION ===== %>
<section class="relative overflow-hidden bg-gradient-to-b from-indigo-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-36">
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900">
        Hiring, <span class="text-indigo-600">simplified.</span>
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-gray-600 leading-relaxed">
        Track candidates from application to offer with structured interviews,
        blind scorecards, and a pipeline built for growing teams.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="<%= signup_path %>" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3 text-base font-medium text-white bg-indigo-600 border border-transparent rounded-lg shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition">
          Start free &rarr;
        </a>
      </div>
      <p class="mt-4 text-sm text-gray-500">No credit card required. Set up in under a minute.</p>
    </div>
  </div>
</section>

<%# ===== FEATURES SECTION ===== %>
<section id="features" class="py-20 sm:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Everything you need to hire well</h2>
      <p class="mt-4 text-lg text-gray-600">Purpose-built for teams who care about a fair, structured hiring process.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <%# Feature 1: Pipeline %>
      <div class="relative bg-white rounded-xl border border-gray-200 p-8 hover:shadow-lg transition-shadow">
        <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-indigo-100 text-indigo-600 mb-5">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Candidate Pipeline</h3>
        <p class="mt-2 text-gray-600">
          Move candidates through Applied, Interviewing, On-hold, Offered, Hired, or Rejected — with full visibility at every stage.
        </p>
      </div>

      <%# Feature 2: Structured Interviews %>
      <div class="relative bg-white rounded-xl border border-gray-200 p-8 hover:shadow-lg transition-shadow">
        <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-green-100 text-green-600 mb-5">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Structured Interviews</h3>
        <p class="mt-2 text-gray-600">
          Define interview phases with panel support. Assign interviewers and phase owners to keep your process consistent.
        </p>
      </div>

      <%# Feature 3: Blind Scorecards %>
      <div class="relative bg-white rounded-xl border border-gray-200 p-8 hover:shadow-lg transition-shadow">
        <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-amber-100 text-amber-600 mb-5">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Blind Scorecards</h3>
        <p class="mt-2 text-gray-600">
          Interviewers submit independent feedback on a 1–5 scale. No bias from seeing others' scores before submitting.
        </p>
      </div>

      <%# Feature 4: Multi-tenant %>
      <div class="relative bg-white rounded-xl border border-gray-200 p-8 hover:shadow-lg transition-shadow">
        <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-purple-100 text-purple-600 mb-5">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Your Own Workspace</h3>
        <p class="mt-2 text-gray-600">
          Each company gets a dedicated subdomain with isolated data. Your hiring data is always private and secure.
        </p>
      </div>

      <%# Feature 5: Bot Detection %>
      <div class="relative bg-white rounded-xl border border-gray-200 p-8 hover:shadow-lg transition-shadow">
        <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-red-100 text-red-600 mb-5">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Bot Detection</h3>
        <p class="mt-2 text-gray-600">
          Server-side honeypot and timing checks flag suspicious applications automatically. Keep your pipeline clean.
        </p>
      </div>

      <%# Feature 6: Roles & Permissions %>
      <div class="relative bg-white rounded-xl border border-gray-200 p-8 hover:shadow-lg transition-shadow">
        <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-teal-100 text-teal-600 mb-5">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Role-Based Access</h3>
        <p class="mt-2 text-gray-600">
          Three tiers — Admin, Hiring Manager, Interviewer — so everyone sees exactly what they need, nothing more.
        </p>
      </div>
    </div>
  </div>
</section>

<%# ===== HOW IT WORKS ===== %>
<section class="py-20 sm:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Up and running in minutes</h2>
      <p class="mt-4 text-lg text-gray-600">Three steps to a better hiring process.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <div class="text-center">
        <div class="flex items-center justify-center w-14 h-14 rounded-full bg-indigo-600 text-white text-xl font-bold mx-auto mb-5">1</div>
        <h3 class="text-lg font-semibold text-gray-900">Create your workspace</h3>
        <p class="mt-2 text-gray-600">Sign up with your company name and get a dedicated subdomain instantly.</p>
      </div>

      <div class="text-center">
        <div class="flex items-center justify-center w-14 h-14 rounded-full bg-indigo-600 text-white text-xl font-bold mx-auto mb-5">2</div>
        <h3 class="text-lg font-semibold text-gray-900">Post open roles</h3>
        <p class="mt-2 text-gray-600">Create roles with custom application questions and share your public careers page.</p>
      </div>

      <div class="text-center">
        <div class="flex items-center justify-center w-14 h-14 rounded-full bg-indigo-600 text-white text-xl font-bold mx-auto mb-5">3</div>
        <h3 class="text-lg font-semibold text-gray-900">Hire with confidence</h3>
        <p class="mt-2 text-gray-600">Review applications, run structured interviews, and make data-driven hiring decisions.</p>
      </div>
    </div>
  </div>
</section>

<%# ===== CTA SECTION ===== %>
<section class="py-20 sm:py-28 bg-indigo-600">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white">Ready to improve your hiring?</h2>
    <p class="mt-4 text-lg text-indigo-100">
      Set up your workspace in under a minute. No credit card, no commitment.
    </p>
    <div class="mt-8">
      <a href="<%= signup_path %>" class="inline-flex items-center justify-center px-8 py-3 text-base font-medium text-indigo-600 bg-white border border-transparent rounded-lg shadow-sm hover:bg-indigo-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-indigo-600 focus:ring-white transition">
        Get started for free &rarr;
      </a>
    </div>
  </div>
</section>

<%# ===== FOOTER ===== %>
<footer class="bg-gray-900 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row justify-between items-center space-y-4 sm:space-y-0">
      <div class="flex items-center space-x-2">
        <svg class="h-6 w-6 text-gray-400" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="2.5"/>
          <path d="M16 6 C22 6 26 10 26 16 C26 22 22 26 16 26 C10 26 6 22 6 16 C6 12 9 9 12 9 C15 9 17 11 17 14 C17 17 15 19 12 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        </svg>
        <span class="text-gray-400 font-semibold">Ouroboros</span>
