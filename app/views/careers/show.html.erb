<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%# Back navigation %>
  <div class="mb-6">
    <%= link_to careers_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to all positions
    <% end %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <%# Header section with title and metadata %>
    <div class="px-6 py-8 sm:px-8 border-b border-gray-200">
      <h1 class="text-3xl font-bold text-gray-900 mb-4"><%= @role.title %></h1>

      <div class="flex flex-wrap gap-3 text-sm text-gray-600">
        <% if @role.location.present? %>
          <span class="inline-flex items-center gap-1.5">
            <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <%= @role.location %>
          </span>
        <% end %>

        <% if @role.remote? %>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 px-3 py-0.5 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Remote
          </span>
        <% end %>

        <% if @role.salary_range.present? %>
          <span class="inline-flex items-center gap-1.5">
            <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= @role.salary_range %>
          </span>
        <% end %>
      </div>
    </div>

    <%# Description / Requirements section %>
    <div class="px-6 py-8 sm:px-8">
      <% if @role.description.present? %>
        <div class="prose prose-gray max-w-none
                    prose-headings:text-gray-900 prose-headings:font-semibold
                    prose-p:text-gray-600 prose-p:leading-relaxed
                    prose-li:text-gray-600
                    prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
                    prose-strong:text-gray-900">
          <%= @role.description %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No description available for this role.</p>
      <% end %>
    </div>

    <%# Apply button section %>
    <div class="px-6 py-6 sm:px-8 bg-gray-50 border-t border-gray-200">
      <%= link_to "Apply for this position",
            job_application_path(slug: @role.slug),
            class: "inline-flex items-center justify-center rounded-md px-6 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 transition-opacity",
            style: "background-color: #{current_company.primary_color || '#4F46E5'};" %>
    </div>
  </div>
</div>
